# Copy to .env and fill in. SentryBugFixer loads this automatically.

# --- Anthropic (the bug-fixing agent) ---
ANTHROPIC_API_KEY=sk-ant-...
# Model used by the agent. Opus 4.8 is the most capable; use claude-sonnet-4-6 for lower cost.
SBF_MODEL=claude-opus-4-8
# Thinking/effort depth: low | medium | high | xhigh | max
SBF_EFFORT=high
# Per-request timeout (seconds). Keeps a hung/overloaded API call from appearing stuck.
SBF_REQUEST_TIMEOUT=300

# --- Sentry (read issues + receive webhooks) ---
# Auth token: https://sentry.io/settings/account/api/auth-tokens/  (needs project:read, event:read)
SENTRY_AUTH_TOKEN=
# Default host. Override for self-hosted Sentry.
SENTRY_HOST=https://sentry.io
# Optional shared secret to validate incoming webhooks (Sentry sends it as sentry-hook-signature; leave blank to skip).
SENTRY_WEBHOOK_SECRET=

# --- GitLab (clone + open merge requests) ---
# Personal access token with `api` + `write_repository` scope.
GITLAB_TOKEN=
# Default host for cloning/MR API. Override for self-hosted GitLab.
GITLAB_HOST=https://gitlab.com

# --- Agent limits ---
SBF_MAX_STEPS=40
SBF_BASH_TIMEOUT=180

# --- Server ---
SBF_HOST=127.0.0.1
SBF_PORT=8000
# Where the SQLite db and cloned repos live.
SBF_DATA_DIR=./data
